{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "dom", "dom.iterable"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"tsBuildInfoFile": ".next/cache/tsbuildinfo.json",
		"noFallthroughCasesInSwitch": true,
		"plugins": [{ "name": "next" }],
		"paths": {
			"@/*": ["./src/*"],
			"@matrix/*": ["./src/features/matrix/*"],
			"@agent/*": ["./src/features/agent/*"],
			"@control/*": ["./src/features/control/*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"src/**/*.ts",
		"src/**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": [".next", "node_modules"]
}
