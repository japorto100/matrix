		"format": "biome format --write ./src",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"_note_bun_test": "DO NOT use `bun test` — it runs bun's native test runner without jsdom and breaks React/DOM tests. Always run `bun run test` (which invokes vitest) or `bunx vitest run`."
