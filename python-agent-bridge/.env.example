# Python Agent Bridge — Environment Variables
# Kopieren nach .env und ausfüllen

# Matrix Homeserver
MATRIX_HOMESERVER_URL=http://localhost:8448

# Bot Matrix-Account (via scripts/register_bot.py erstellen)
MATRIX_BOT_USER_ID=@trading-agent:matrix.local
MATRIX_BOT_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
# Nach erstem Login setzen (aus Login-Response):
# MATRIX_BOT_ACCESS_TOKEN=syt_...

MATRIX_DEVICE_NAME=TradingAgent-Bridge

# E2EE Key Store (SQLite, wird automatisch erstellt)
MATRIX_STORE_PATH=./data/matrix_store

# Bestehender Agent-Service (Hauptprojekt: 11500, isolierter Test: 8094)
AGENT_SERVICE_URL=http://localhost:8094
AGENT_TIMEOUT_SEC=120

# NATS (optional — für Go Appservice Koordination)
NATS_URL=nats://localhost:4222

# Service
HOST=127.0.0.1
PORT=8097
