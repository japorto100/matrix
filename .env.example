# Matrix Stack — Root Environment Variables
# ---------------------------------------------------------------------------
# Kopieren nach `.env` (repo-root) und Werte ausfuellen.
# Diese Vars werden von docker-compose.yml interpoliert (${VAR}).
# Sub-Projekte (go-appservice, python-backend, frontend_merger, control-ui,
# nextjs-chat, agent-chat) haben **eigene** .env.example mit ihren spezifischen
# Vars — diese Datei hier deckt NUR compose-level configuration ab.
#
# Laden: Docker/Podman liest .env im gleichen Dir wie docker-compose.yml
#   automatisch. Für custom path: `podman-compose --env-file my.env up -d`.

# ═══════════════════════════════════════════════════════════════════════════
# Tuwunel (Matrix Homeserver) — Version-Switcher
# ═══════════════════════════════════════════════════════════════════════════
# Image-Tag steuern. Default im compose: v1.6.0-rc.
# TUWUNEL_IMAGE=ghcr.io/matrix-construct/tuwunel:v1.5.2       # stable fallback
# TUWUNEL_IMAGE=ghcr.io/matrix-construct/tuwunel:v1.6.0-rc    # default (RC)
# TUWUNEL_IMAGE=ghcr.io/matrix-construct/tuwunel:latest       # bleeding edge

# ═══════════════════════════════════════════════════════════════════════════
# PostgreSQL (pgvector:pg17, Port 5433)
# ═══════════════════════════════════════════════════════════════════════════
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hindsight_dev

# ═══════════════════════════════════════════════════════════════════════════
# OpenSandbox (Code Execution Sandbox)
# ═══════════════════════════════════════════════════════════════════════════
# Shared Secret für Sandbox-API — in Prod MUSS das ein zufaelliger 32+ char
# String sein (openssl rand -hex 32).
OPEN_SANDBOX_API_KEY=dev-sandbox-key

# Docker/Podman socket mount (nur für opensandbox container-in-container).
# Podman rootless: /run/user/$UID/podman/podman.sock
# Docker:          /var/run/docker.sock
# CONTAINER_SOCK=/var/run/docker.sock

# ═══════════════════════════════════════════════════════════════════════════
# LiveKit (Video/Voice Calls, profile=calls)
# ═══════════════════════════════════════════════════════════════════════════
# Generieren mit scripts/harden-env.py. In Prod zwingend setzen.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-in-production

# ═══════════════════════════════════════════════════════════════════════════
# Cloudflare Tunnel (profile=tunnel)
# ═══════════════════════════════════════════════════════════════════════════
# Tunnel-Token aus `cloudflared tunnel create` → dashboard.cloudflare.com.
# Leer lassen wenn profile=tunnel nicht verwendet wird.
CLOUDFLARED_TUNNEL_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
# Nicht-compose Vars (teil von sub-project .env — hier als Overview)
# ═══════════════════════════════════════════════════════════════════════════
# Die folgenden Vars gehören in die Sub-Projekt-.env Files (NICHT hier):
# - API-Keys (ANTHROPIC/OPENAI/OPENROUTER/GEMINI) → python-backend/.env
# - Matrix-Tokens (AS_TOKEN/HS_TOKEN)              → go-appservice/.env.development
# - Artifact-Signing-Secrets                        → go-appservice/.env.development
# - Frontend-Pfade (MATRIX_HOMESERVER_URL etc.)     → frontend_merger/.env.local
#
# Siehe docs/env-vars.md für vollständige Übersicht aller Env-Vars im Stack.
