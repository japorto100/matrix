# Matrix Ingestion Worker — Environment Variables
#
# This worker runs in its own venv (Venv 2) on Port 8098.
# It is intentionally decoupled from the main agent runtime (D17).

# ─── Database (shared with main venv via memory_engine + tracking/jobs) ───
INGESTION_DB_URL=postgresql://postgres@localhost:5433/hindsight_dev
HINDSIGHT_DB_URL=postgresql://postgres@localhost:5433/hindsight_dev

# ─── Go Storage Gateway (D12 capability-based access) ────────────────────
# Used by clients/go_storage.py to fetch signed URLs for SeaweedFS.
# This worker NEVER has direct S3 credentials.
ARTIFACT_GATEWAY_BASE_URL=http://127.0.0.1:8090

# ─── KG Pipeline (Phase 2 — Stub returns skip in Phase 1) ────────────────
KG_PIPELINE_URL=http://127.0.0.1:8099
KG_PIPELINE_ENABLED=false

# ─── Embedder ────────────────────────────────────────────────────────────
# Lightweight default (no model downloads). Set to sentence_transformer to enable local embeddings.
EMBEDDER_PROVIDER=deterministic
EMBEDDER_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDER_ENABLED=true
EMBEDDER_ALLOW_DOWNLOAD=false

# ─── Chunker ─────────────────────────────────────────────────────────────
CHUNKER_NAME=token
CHUNKER_SIZE=500
CHUNKER_OVERLAP=50

# ─── Worker ──────────────────────────────────────────────────────────────
INGESTION_HOST=127.0.0.1
INGESTION_PORT=8098
LOG_LEVEL=INFO
