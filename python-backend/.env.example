# Python Backend — Environment Variables
# Kopieren nach .env und Secrets ausfuellen.
# Services: agent (8094), bridge (8097), voice (LiveKit Worker), memory (8093)

# ─── Agent / LLM (provider-agnostisch) ──────────────────────────────────────
# anthropic (default) | openai | openai-compatible
AGENT_PROVIDER=anthropic
AGENT_MODEL=claude-sonnet-4-6
AGENT_UTILITY_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# OpenAI-compatible: Ollama, vLLM, OpenRouter, LM Studio, Azure
# OPENAI_BASE_URL=http://localhost:11434/v1
# LiteLLM Multi-Provider Router (optional)
AGENT_USE_LITELLM=false
# Tool Call Timeout (Sekunden)
AGENT_TOOL_TIMEOUT_SEC=30
AGENT_MAX_ITERATIONS=10

# ─── LangGraph (exec-10) ───────────────────────────────────────────────────
# true = LangGraph StateGraph, false = Legacy while-Loop
AGENT_USE_LANGGRAPH=true

# ─── Skills + Self-Evolution (exec-10) ──────────────────────────────────────
# Skill-Generation aus Failures (MetaClaw Pattern)
AGENT_SKILL_EVOLUTION=false
# Process Reward Model (LLM-as-Judge fuer Trajectories)
AGENT_PRM_ENABLED=false
# LoRA Fine-Tuning (deaktiviert, Infrastruktur vorbereitet)
AGENT_RL_ENABLED=false
AGENT_RL_BACKEND=openai
AGENT_RL_MIN_SAMPLES=50
# Idle-Window Detection (Training nur bei User-Inaktivitaet)
AGENT_IDLE_THRESHOLD_MIN=30

# ─── Context Management (exec-10 Phase 5) ──────────────────────────────────
# Summarization Trigger: Fraction des Context-Windows (0.0-1.0)
AGENT_SUMMARIZE_THRESHOLD=0.7
# Anzahl Messages die nach Summarization vollstaendig bleiben
AGENT_SUMMARIZE_KEEP_MESSAGES=20
# Model fuer Summarization (schnell + guenstig)
AGENT_SUMMARIZE_MODEL=claude-haiku-4-5
# Max Zeichenlaenge fuer Tool-Results bevor Offload
AGENT_TOOL_RESULT_MAX_CHARS=2000

# ─── Security ──────────────────────────────────────────────────────────────
# Erlaubtes Verzeichnis fuer .skill ZIP Uploads
SKILL_UPLOAD_DIR=/tmp/skill-uploads

# Optional local ML models (keep OFF by default on weak machines)
# PromptGuard (transformers+torch) is used by sanitizer only when enabled.
AGENT_PROMPT_GUARD_ENABLED=false
HF_HOME=~/.cache/huggingface

# ─── A2A Remote Agents (exec-10 Phase 4, optional) ─────────────────────────
# Remote-Agent URLs fuer Inter-Agent Delegation
# AGENT_REMOTE_FUNDAMENTALS=http://remote-host:8094
# AGENT_REMOTE_RESEARCHER=http://remote-host:8095

# ─── STT / TTS (provider-agnostisch) ────────────────────────────────────────
# STT: whisper-local (default, Open Source) | openai
AGENT_STT_PROVIDER=whisper-local
WHISPER_MODEL=base
# TTS: piper (default, Open Source) | openai | kokoro
AGENT_TTS_PROVIDER=piper
# AGENT_TTS_MODEL=tts-1
# AGENT_TTS_VOICE=alloy
# AGENT_TTS_BASE_URL=

# ─── LiveKit (Voice AI Pipeline) ────────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-in-production

# ─── Bridge (NATS Consumer, exec-05) ───────────────────────────────────────
NATS_URL=nats://localhost:4222
AGENT_USER_ID=@agent-trading:matrix.local
AGENT_SERVICE_URL=http://127.0.0.1:8094
AGENT_TIMEOUT_SEC=120

# ─── Matrix Bot (genutzt von setup-users.ps1) ──────────────────────────────
MATRIX_HOMESERVER_URL=http://localhost:8448
MATRIX_BOT_USER_ID=@agent-bot:matrix.local
MATRIX_BOT_PASSWORD=
MATRIX_BOT_ACCESS_TOKEN=
MATRIX_DEVICE_NAME=AgentBridge-Dev
MATRIX_STORE_PATH=./data/matrix_store
MENTION_ONLY_IN_GROUPS=true
ALLOWED_HOMESERVERS=matrix.local

# ─── Go Gateway ─────────────────────────────────────────────────────────────
GO_GATEWAY_BASE_URL=http://127.0.0.1:8090

# ─── Artifact Storage (exec-15 D12: capability-based access) ───────────────
# Python NEVER has direct SeaweedFS credentials. The ingestion pipeline
# (python-backend/ingestion/) uses GoStorageClient (httpx wrapper) to:
#   1. POST {GO_GATEWAY_BASE_URL}/api/v1/storage/artifacts/upload-url
#      → receives signed PUT URL
#   2. PUT bytes directly to signed URL (SeaweedFS S3 endpoint, no Go hop)
#   3. POST .../mark-ready to finalize
# All credentials live in go-appservice/.env.development under
# ARTIFACT_STORAGE_S3_*. Python only needs GO_GATEWAY_BASE_URL above.
ARTIFACT_GATEWAY_BASE_URL=http://127.0.0.1:8090

# ─── Ingestion Worker (exec-15 Slice 2, Venv 2 — Port 8098) ───────────────
# Decoupled extraction pipeline (D13-D17). The agent main runtime never
# imports from python-backend/ingestion/ — communication is via HTTP only.
# agent/control/ingestion.py is the thin httpx proxy boundary.
INGESTION_WORKER_URL=http://127.0.0.1:8098
INGESTION_PROXY_TIMEOUT_S=30

# ─── KG Pipeline Worker (exec-15 Slice 2, Venv 3 — Port 8099, Phase 2) ────
# Currently a Phase 1 skeleton. Set ENABLED=true after Phase 2 activation
# (see python-backend/kg_pipeline/README.md).
KG_PIPELINE_URL=http://127.0.0.1:8099
KG_PIPELINE_ENABLED=false

# Heavy extraction worker (exec-15 Phase 2, Venv 3 — Port 8101)
EXTRACTION_LAYOUT_URL=http://127.0.0.1:8101
EXTRACTION_LAYOUT_ENABLED=false

# ─── Hindsight Memory Engine (exec-11) ─────────────────────────────────────
# PostgreSQL mit pgvector — Setup: .\scripts\setup-postgres.ps1 (Port 5433)
# Docker Alternative: docker-compose up postgres (Port 5432)
# LLM/Embeddings nutzen unsere zentrale AGENT_PROVIDER Konfiguration (oben)
# Audit Logging (exec-12) nutzt AUDIT_DB_URL oder Fallback auf HINDSIGHT_DB_URL
# Auskommentiert = Memory deaktiviert (Agent funktioniert ohne)
# HINDSIGHT_DB_URL=postgresql://postgres@localhost:5433/hindsight_dev
# Consolidation: false = braucht hindsight-worker, true = inline (Dev ohne Worker)
HINDSIGHT_SYNC_TASKS=false

# ─── Legacy Memory Service (KuzuDB/ChromaDB) ──────────────────────────────
KG_PROVIDER=kuzu
KG_FORCE_SQLITE=false
VECTOR_STORE_PROVIDER=chroma
VECTOR_STORE_MOCK=false
MEMORY_CACHE_PROVIDER=local

# ─── Audit Logging (exec-12) ───────────────────────────────────────────────
# Leer = nutzt HINDSIGHT_DB_URL (shared PG, Tabelle audit_events)
# Ohne PG: JSON Lines Fallback in data/audit/
# AUDIT_DB_URL=postgresql://postgres:postgres@localhost:5432/hindsight_dev

# ─── OpenSandbox (exec-12 Phase 1) ─────────────────────────────────────────
# URL des OpenSandbox Servers (docker-compose --profile sandbox up opensandbox)
# Container Socket fuer OpenSandbox (Podman/Docker)
# Podman: /run/podman/podman.sock oder /run/user/1000/podman/podman.sock
# Docker: /var/run/docker.sock (default)
# CONTAINER_SOCK=/var/run/docker.sock
OPEN_SANDBOX_URL=http://localhost:8100
OPEN_SANDBOX_API_KEY=
# Docker Image fuer Code-Execution Sandboxes
OPEN_SANDBOX_IMAGE=opensandbox/code-interpreter:v1.0.2
# Default Timeout in Minuten (10 = Standard, 30 = Backtesting)
OPEN_SANDBOX_TIMEOUT_MIN=10
# Resource Limits pro Sandbox
OPEN_SANDBOX_CPU=1
OPEN_SANDBOX_MEMORY=2Gi

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
GRPC_ENABLED=0
