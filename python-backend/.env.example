# Python Backend — Environment Variables
# Kopieren nach .env und Secrets ausfuellen.
# Services: agent (8094), bridge (8097), voice (LiveKit Worker), memory (8093)

# ─── LiteLLM Gateway (exec-16) ──────────────────────────────────────────────
# Agent → LiteLLM (:4000) → Provider. User-Model + Key aus DB (control-ui).
LITELLM_BASE_URL=http://localhost:4000
LITELLM_PORT=4000
# Internes Utility-Model (Summarization, Skills, Completion Gates — kein User-Setting)
AGENT_DEFAULT_UTILITY_MODEL=

# ─── LLM Provider API Keys (exec-16) ───────────────────────────────────────
# Setze nur die Keys fuer Provider die du nutzen willst.
# Bei LiteLLM: Wildcard-Routing, Model-Name bestimmt den Provider automatisch.
# Docs: https://openrouter.ai/docs | https://docs.litellm.ai/docs/providers

# US / EU Provider
OPENROUTER_API_KEY=                   # OpenRouter (500+ Models, Free Tier)
# GEMINI_API_KEY=                     # Google Gemini
# COHERE_API_KEY=                     # Cohere (Command R+, Embed, Rerank)
# MISTRAL_API_KEY=                    # Mistral (Mistral Large, Codestral)
# GROQ_API_KEY=                       # Groq (ultra-fast Llama/Mixtral)
# AWS_ACCESS_KEY_ID=                  # AWS Bedrock
# AWS_SECRET_ACCESS_KEY=
# AZURE_API_KEY=                      # Azure OpenAI
# AZURE_API_BASE=

# Chinesische Provider (alle OpenAI-kompatibel)
# DEEPSEEK_API_KEY=                   # DeepSeek (V3.2, R1, guenstig)
# DASHSCOPE_API_KEY=                  # Qwen / Alibaba DashScope
# ZHIPU_API_KEY=                      # Zhipu AI (GLM-5, Top China)
# MOONSHOT_API_KEY=                   # Moonshot / Kimi (256K Context)
# BAICHUAN_API_KEY=                   # Baichuan 4
# YI_API_KEY=                         # Yi / 01.AI (Yi-Lightning)
# MINIMAX_API_KEY=                    # MiniMax
# STEPFUN_API_KEY=                    # StepFun (Step-2)

# Lokale Inference (kein API Key, Defaults in litellm-gateway/config.yaml)
# OLLAMA_BASE_URL=http://localhost:11434      # Ollama (default 11434)
# VLLM_BASE_URL=http://localhost:8000/v1      # vLLM (default 8000)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1  # LM Studio (default 1234)

# ─── LiteLLM Gateway ───────────────────────────────────────────────────────
LITELLM_PORT=4000
# LITELLM_MASTER_KEY=sk-litellm-local        # Virtual Key (optional)
# Cost Tracking (exec-16 Stufe 3.4): gleiche PG wie Hindsight
# Aktiviert LiteLLM Spend Tracking + Dashboard unter localhost:4000/ui
# LITELLM_DATABASE_URL=postgresql://postgres@localhost:5433/hindsight_dev

# ─── Key Encryption (exec-16 Stufe 2.5) ────────────────────────────────────
# 32 Bytes hex-encoded. Generieren: python -c "import secrets; print(secrets.token_hex(32))"
# KEY_ENCRYPTION_SECRET=
# KEY_VAULT_BACKEND=aesgcm

# Tool Call Timeout (Sekunden)
AGENT_TOOL_TIMEOUT_SEC=30
AGENT_MAX_ITERATIONS=10

# ─── LangGraph (exec-10) ───────────────────────────────────────────────────
# true = LangGraph StateGraph, false = Legacy while-Loop
AGENT_USE_LANGGRAPH=true

# ─── Skills + Self-Evolution (exec-10) ──────────────────────────────────────
# Skill-Generation aus Failures (MetaClaw Pattern)
AGENT_SKILL_EVOLUTION=false
# Process Reward Model (LLM-as-Judge fuer Trajectories)
AGENT_PRM_ENABLED=false
# LoRA Fine-Tuning (deaktiviert, Infrastruktur vorbereitet)
AGENT_RL_ENABLED=false
AGENT_RL_BACKEND=openai
AGENT_RL_MIN_SAMPLES=50
# Idle-Window Detection (Training nur bei User-Inaktivitaet)
AGENT_IDLE_THRESHOLD_MIN=30

# ─── Context Management (exec-10 Phase 5) ──────────────────────────────────
# Summarization Trigger: Fraction des Context-Windows (0.0-1.0)
AGENT_SUMMARIZE_THRESHOLD=0.7
# Anzahl Messages die nach Summarization vollstaendig bleiben
AGENT_SUMMARIZE_KEEP_MESSAGES=20
# Model fuer Summarization (schnell + guenstig)
AGENT_SUMMARIZE_MODEL=claude-haiku-4-5
# Max Zeichenlaenge fuer Tool-Results bevor Offload
AGENT_TOOL_RESULT_MAX_CHARS=2000

# ─── Security ──────────────────────────────────────────────────────────────
# Erlaubtes Verzeichnis fuer .skill ZIP Uploads
SKILL_UPLOAD_DIR=/tmp/skill-uploads

# Optional local ML models (keep OFF by default on weak machines)
# PromptGuard (transformers+torch) is used by sanitizer only when enabled.
AGENT_PROMPT_GUARD_ENABLED=false
HF_HOME=~/.cache/huggingface

# ─── A2A Remote Agents (exec-10 Phase 4, optional) ─────────────────────────
# Remote-Agent URLs fuer Inter-Agent Delegation
# AGENT_REMOTE_FUNDAMENTALS=http://remote-host:8094
# AGENT_REMOTE_RESEARCHER=http://remote-host:8095

# ─── STT / TTS (provider-agnostisch) ────────────────────────────────────────
# STT: whisper-local (default, Open Source) | openai
# For weak machines: keep voice features off by default.
# If enabled, prefer openai STT (remote) or whisper-local (CPU) explicitly.
AGENT_STT_PROVIDER=off
WHISPER_MODEL=base
# TTS: piper (default, Open Source) | openai | kokoro
AGENT_TTS_PROVIDER=piper
# AGENT_TTS_MODEL=tts-1
# AGENT_TTS_VOICE=alloy
# AGENT_TTS_BASE_URL=

# ─── LiveKit (Voice AI Pipeline) ────────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-in-production

# ─── Bridge (NATS Consumer, exec-05) ───────────────────────────────────────
NATS_URL=nats://localhost:4222
AGENT_USER_ID=@agent-trading:matrix.local
AGENT_SERVICE_URL=http://127.0.0.1:8094
AGENT_TIMEOUT_SEC=120

# ─── Matrix Bot (genutzt von setup-users.ps1) ──────────────────────────────
MATRIX_HOMESERVER_URL=http://localhost:8448
MATRIX_BOT_USER_ID=@agent-bot:matrix.local
MATRIX_BOT_PASSWORD=
MATRIX_BOT_ACCESS_TOKEN=
MATRIX_DEVICE_NAME=AgentBridge-Dev
MATRIX_STORE_PATH=./data/matrix_store
MENTION_ONLY_IN_GROUPS=true
ALLOWED_HOMESERVERS=matrix.local

# ─── Go Gateway ─────────────────────────────────────────────────────────────
GO_GATEWAY_BASE_URL=http://127.0.0.1:8090

# ─── Artifact Storage (exec-15 D12: capability-based access) ───────────────
# Python NEVER has direct SeaweedFS credentials. The ingestion pipeline
# (python-backend/ingestion/) uses GoStorageClient (httpx wrapper) to:
#   1. POST {GO_GATEWAY_BASE_URL}/api/v1/storage/artifacts/upload-url
#      → receives signed PUT URL
#   2. PUT bytes directly to signed URL (SeaweedFS S3 endpoint, no Go hop)
#   3. POST .../mark-ready to finalize
# All credentials live in go-appservice/.env.development under
# ARTIFACT_STORAGE_S3_*. Python only needs GO_GATEWAY_BASE_URL above.
ARTIFACT_GATEWAY_BASE_URL=http://127.0.0.1:8090

# ─── Ingestion Worker (exec-15 Slice 2, Venv 2 — Port 8098) ───────────────
# Decoupled extraction pipeline (D13-D17). The agent main runtime never
# imports from python-backend/ingestion/ — communication is via HTTP only.
# agent/control/ingestion.py is the thin httpx proxy boundary.
INGESTION_WORKER_URL=http://127.0.0.1:8098
INGESTION_PROXY_TIMEOUT_S=30

# ─── KG Pipeline Worker (exec-15 Slice 2, Venv 3 — Port 8099, Phase 2) ────
# Currently a Phase 1 skeleton. Set ENABLED=true after Phase 2 activation
# (see python-backend/kg_pipeline/README.md).
KG_PIPELINE_URL=http://127.0.0.1:8099
KG_PIPELINE_ENABLED=false

# Heavy extraction worker (exec-15 Phase 2, Venv 3 — Port 8101)
EXTRACTION_LAYOUT_URL=http://127.0.0.1:8101
EXTRACTION_LAYOUT_ENABLED=false

# ─── Hindsight Memory Engine (exec-11) ─────────────────────────────────────
# PostgreSQL mit pgvector — Setup: .\scripts\setup-postgres.ps1 (Port 5433)
# Docker Alternative: docker-compose up postgres (Port 5432)
# LLM/Embeddings nutzen unsere zentrale AGENT_PROVIDER Konfiguration (oben)
# Audit Logging (exec-12) nutzt AUDIT_DB_URL oder Fallback auf HINDSIGHT_DB_URL
# Auskommentiert = Memory deaktiviert (Agent funktioniert ohne)
# HINDSIGHT_DB_URL=postgresql://postgres@localhost:5433/hindsight_dev
# Consolidation: false = braucht hindsight-worker, true = inline (Dev ohne Worker)
HINDSIGHT_SYNC_TASKS=false

# ─── Legacy Memory Service (KuzuDB/ChromaDB) ──────────────────────────────
KG_PROVIDER=kuzu
KG_FORCE_SQLITE=false
VECTOR_STORE_PROVIDER=chroma
# Lightweight default: avoid any embedding model downloads in vector store.
VECTOR_STORE_MOCK=true
MEMORY_CACHE_PROVIDER=local

# ─── Audit Logging (exec-12) ───────────────────────────────────────────────
# Leer = nutzt HINDSIGHT_DB_URL (shared PG, Tabelle audit_events)
# Ohne PG: JSON Lines Fallback in data/audit/
# AUDIT_DB_URL=postgresql://postgres:postgres@localhost:5432/hindsight_dev

# ─── OpenSandbox (exec-12 Phase 1) ─────────────────────────────────────────
# URL des OpenSandbox Servers (docker-compose --profile sandbox up opensandbox)
# Container Socket fuer OpenSandbox (Podman/Docker)
# Podman: /run/podman/podman.sock oder /run/user/1000/podman/podman.sock
# Docker: /var/run/docker.sock (default)
# CONTAINER_SOCK=/var/run/docker.sock
OPEN_SANDBOX_URL=http://localhost:8100
OPEN_SANDBOX_API_KEY=
# Docker Image fuer Code-Execution Sandboxes
OPEN_SANDBOX_IMAGE=opensandbox/code-interpreter:v1.0.2
# Default Timeout in Minuten (10 = Standard, 30 = Backtesting)
OPEN_SANDBOX_TIMEOUT_MIN=10
# Resource Limits pro Sandbox
OPEN_SANDBOX_CPU=1
OPEN_SANDBOX_MEMORY=2Gi

# ─── Auto-Migrations (exec-17) ──────────────────────────────────────────────
# Runs `alembic upgrade head` on agent service startup.
# Idempotent, safe. Set to false to run migrations manually.
AGENT_AUTO_MIGRATE=true

# ─── OpenTelemetry (exec-17: Observability) ────────────────────────────────
# Set OTEL_ENABLED=true to send traces/metrics/logs to OpenObserve.
# DevStack sets these automatically when -SkipObservability is not used.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:5081
OPENOBSERVE_USER=root@example.com
OPENOBSERVE_PASSWORD=Complexpass#123

# ─── Langfuse LLM Observability (exec-17 Phase 3) ──────────────────────────
# Opt-in: tracks LLM prompts/responses/cost in Langfuse dashboard.
# Complements OTel traces with LLM-specific features.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
GRPC_ENABLED=0

# ═══════════════════════════════════════════════════════════════════════════
# Environment Vars Addendum (gescannt aus source, 2026-04-17)
# ═══════════════════════════════════════════════════════════════════════════

# ─── LLM Provider direkte Keys (bypass LiteLLM) ────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
# OPENROUTER_API_KEY existiert schon oben

# ─── Agent Config (LangGraph / Skills / Memory) ────────────────────────────
AGENT_MEMORY_ENGINE=auto
AGENT_MODEL=
AGENT_SKILLS_SOURCE=db
AGENT_SKILL_COVERAGE_GATE=false
AGENT_SKILL_COVERAGE_THRESHOLD=0.8
AGENT_SKILL_FINDER_MAX_TOKENS=4000
AGENT_SKILL_FINDER_TOP_K=5
AGENT_SKILL_ITERATIVE_MAX_ROUNDS=3
AGENT_SKILL_ITERATIVE_SEARCH=false
AGENT_SKILL_OFFLINE_TASKS=false
AGENT_SKILL_REFINEMENT=false
AGENT_SKILL_REFINE_MODE=patch
HARNESS_SAVE_MODE=both

# ─── Ingestion Pipeline ────────────────────────────────────────────────────
INGESTION_HOST=127.0.0.1
INGESTION_PORT=8098
INGESTION_WORKER_SHARED_SECRET=
CHUNKER_NAME=sliding-window
CHUNKER_SIZE=512
CHUNKER_OVERLAP=64
EMBEDDER_PROVIDER=local
EMBEDDER_ALLOW_MODEL_DOWNLOAD=false
ALLOW_MODEL_DOWNLOADS=false
PDF_EXTRACTOR=pypdf
EXTRACTION_LAYOUT_TIMEOUT_S=30

# ─── KG Backends ───────────────────────────────────────────────────────────
KG_KUZU_PATH=./data/kg/kuzu
KG_SQLITE_PATH=./data/kg/kg.sqlite3
KG_FALKORDB_URL=redis://localhost:6379
KG_FALKORDB_GRAPH=tradeviewfusion

# ─── Vector Store ──────────────────────────────────────────────────────────
VECTOR_STORE_PATH=./data/vector
VECTOR_STORE_PGVECTOR_DSN=
VECTOR_STORE_PGVECTOR_TABLE=embeddings
VECTOR_STORE_LANCE_TABLE=memory
VECTOR_STORE_LANCE_HYBRID=false

# ─── Hindsight API (interne Retrieval-Pipeline) ────────────────────────────
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_BASE_URL=
HINDSIGHT_API_LLM_API_KEY=sk-litellm
HINDSIGHT_API_LLM_MODEL=
HINDSIGHT_API_DATABASE_URL=
HINDSIGHT_API_EMBEDDINGS_PROVIDER=local
HINDSIGHT_API_RERANKER_PROVIDER=local
HINDSIGHT_API_SKIP_LLM_VERIFICATION=true
HINDSIGHT_API_LAZY_RERANKER=true

# ─── MemoryFusion Engine ───────────────────────────────────────────────────
MEMORY_FUSION_SUMMARY_LLM_PROVIDER=inherit
MEMORY_FUSION_SUMMARY_EXTRACTION_MODE=concise
MEMORY_FUSION_SUMMARY_STRATEGY=
MEMORY_FUSION_VERBATIM_LLM_PROVIDER=inherit
MEMORY_FUSION_VERBATIM_EXTRACTION_MODE=strict
MEMORY_FUSION_VERBATIM_STRATEGY=
MEMPALACE_PALACE_PATH=./data/memory/palace

# ─── Sandbox (exec-12) ─────────────────────────────────────────────────────
OPENSANDBOX_SERVER_URL=http://127.0.0.1:8100
SANDBOX_CODE_IMAGE=tradeview/sandbox-code-interpreter:v1
SANDBOX_BROWSER_IMAGE=tradeview/sandbox-browser:v1
SANDBOX_TOOL_TIMEOUT_SEC=1800

# ─── Matrix Bot Flags ──────────────────────────────────────────────────────
MATRIX_E2EE_ENABLED=false

# ─── Mock Agent (dev-only) ─────────────────────────────────────────────────
MOCK_HOST=127.0.0.1

# ─── Redis (fuer Cache-Adapter) ────────────────────────────────────────────
PYTHON_REDIS_URL=redis://127.0.0.1:6379/0

# ─── OpenObserve Org (Telemetry) ───────────────────────────────────────────
OPENOBSERVE_ORG=default

# ─── Additional Vars scanned 2026-04-17 (merger integration) ───────────────

# ─── Agent Provider Override ───────────────────────────────────────────────
# Überschreibt AGENT_DEFAULT_UTILITY_MODEL für Provider-Selection (openai/anthropic/openrouter/local).
# Leer → Default-Auswahl laut AGENT_MODEL config.
AGENT_PROVIDER=

# ─── Agent TTS Voice (Voice-Service) ───────────────────────────────────────
# Voice-ID für TTS-Synthese (z.B. "alloy" für OpenAI, "hatsune-miku" für local).
# Leer → Provider-Default.
AGENT_TTS_VOICE=

# ─── Service Binding (FastAPI / uvicorn host/port) ─────────────────────────
# Übernommen von uvicorn-default wenn nicht gesetzt (0.0.0.0:8000).
# Python sub-services (ingestion/memory/agent) nutzen eigene INGESTION_HOST/PORT etc.
HOST=0.0.0.0
PORT=8000

# ─── Storage Health-Check only (NO direct S3 access!) ───────────────────────
# Agent health-monitoring endpoint — NICHT für upload/download (capability-based via gateway)
# SEAWEEDFS_HEALTH_URL=http://localhost:8333       # default seaweedfs
# SEAWEEDFS_HEALTH_URL=http://localhost:3900       # switch to garage
