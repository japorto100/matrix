# Go Appservice — Environment Variables
# Kopieren nach .env.development (oder .env.production) und ausfüllen
# GO_ENV=development|production steuert welche Datei geladen wird

# Matrix Homeserver
MATRIX_HOMESERVER_URL=http://localhost:8448
MATRIX_SERVER_NAME=matrix.local

# Appservice URL (wie Tuwunel den Appservice erreicht)
MATRIX_APPSERVICE_URL=http://localhost:29318
MATRIX_APPSERVICE_PORT=29318

# Tokens — generieren mit:
#   PowerShell: [System.Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).ToLower()
#   WSL: openssl rand -hex 32
MATRIX_AS_TOKEN=REPLACE_WITH_GENERATED_AS_TOKEN
MATRIX_HS_TOKEN=REPLACE_WITH_GENERATED_HS_TOKEN

# Bot User-ID (der "Haupt-Bot" des Appservice)
MATRIX_BOT_USER_ID=@appservice-bot:matrix.local

# NATS (für Event-Weiterleitung an Python Agent Bridge)
NATS_URL=nats://localhost:4222

# Agent-Namespace Prefix (z.B. "agent-" → @agent-trading:matrix.local)
MATRIX_AGENT_PREFIX=agent-

# Logging
LOG_LEVEL=info

# E2EE — Option C: Go Appservice übernimmt Crypto (Python Bridge bekommt Klartext)
# false = deaktiviert (Standard für Tests, kein libolm nötig)
# true  = OlmMachine aktiv, SQLite-Store unter MATRIX_CRYPTO_DB_PATH
MATRIX_E2EE_ENABLED=false
MATRIX_CRYPTO_DB_PATH=./data/crypto.sqlite3
# Zufälligen Key generieren: openssl rand -hex 32
MATRIX_CRYPTO_PICKLE_KEY=changeme-use-random-32-chars-here

# C-8: Passphrase für lokales Megolm Key Backup (verschlüsselte Datei in data/)
MATRIX_KEY_BACKUP_PASSWORD=matrix-appservice-key-backup-2026

# ─── Agent Service (Python, Port 8094) ──────────────────────────────────────
AGENT_SERVICE_URL=http://127.0.0.1:8094
# AGENT_SERVICE_TIMEOUT_MS=5000

# ─── Memory Service (Python, Port 8093) — späterer Slice ────────────────────
MEMORY_SERVICE_URL=http://127.0.0.1:8093
# MEMORY_SERVICE_TIMEOUT_MS=5000
