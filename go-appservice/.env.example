# Go Appservice — Environment Variables
# Kopieren nach .env.development (oder .env.production) und ausfüllen
# GO_ENV=development|production steuert welche Datei geladen wird

# Matrix Homeserver
MATRIX_HOMESERVER_URL=http://localhost:8448
MATRIX_SERVER_NAME=matrix.local

# Appservice URL (wie Tuwunel den Appservice erreicht)
MATRIX_APPSERVICE_URL=http://localhost:29318
MATRIX_APPSERVICE_PORT=29318

# Tokens — generieren mit:
#   PowerShell: [System.Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).ToLower()
#   WSL: openssl rand -hex 32
MATRIX_AS_TOKEN=REPLACE_WITH_GENERATED_AS_TOKEN
MATRIX_HS_TOKEN=REPLACE_WITH_GENERATED_HS_TOKEN

# Bot User-ID (der "Haupt-Bot" des Appservice)
MATRIX_BOT_USER_ID=@appservice-bot:matrix.local

# NATS (für Event-Weiterleitung an Python Agent Bridge)
NATS_URL=nats://localhost:4222

# Agent-Namespace Prefix (z.B. "agent-" → @agent-trading:matrix.local)
MATRIX_AGENT_PREFIX=agent-

# Logging
LOG_LEVEL=info

# E2EE — Option C: Go Appservice übernimmt Crypto (Python Bridge bekommt Klartext)
# false = deaktiviert (Standard für Tests, kein libolm nötig)
# true  = OlmMachine aktiv, SQLite-Store unter MATRIX_CRYPTO_DB_PATH
MATRIX_E2EE_ENABLED=false
MATRIX_CRYPTO_DB_PATH=./data/crypto.sqlite3
# Zufälligen Key generieren: openssl rand -hex 32
MATRIX_CRYPTO_PICKLE_KEY=changeme-use-random-32-chars-here

# C-8: Passphrase für lokales Megolm Key Backup (verschlüsselte Datei in data/)
MATRIX_KEY_BACKUP_PASSWORD=matrix-appservice-key-backup-2026

# ─── Agent Service (Python, Port 8094) ──────────────────────────────────────
AGENT_SERVICE_URL=http://127.0.0.1:8094
# AGENT_SERVICE_TIMEOUT_MS=5000

# ─── Memory Service (Python, Port 8093) — späterer Slice ────────────────────
MEMORY_SERVICE_URL=http://127.0.0.1:8093
# MEMORY_SERVICE_TIMEOUT_MS=5000

# ─── Artifact Storage (exec-15 Slice 1, capability-based via signed URLs) ──
# 1:1 ENV var naming with tradeview-fusion main project for portability.
# D12: Go is control plane (S3 credentials, signing, metadata, audit).
# Python ingest + control-ui frontend never get S3 credentials — they fetch
# signed URLs from these endpoints and PUT/GET bytes directly to SeaweedFS.

# Provider: filesystem (dev fallback) | s3 | seaweedfs
ARTIFACT_STORAGE_PROVIDER=seaweedfs

# Filesystem provider (only used if PROVIDER=filesystem)
ARTIFACT_STORAGE_BASE_DIR=data/storage/objects

# S3 / SeaweedFS provider (used if PROVIDER=s3 or seaweedfs)
ARTIFACT_STORAGE_S3_ENDPOINT=http://127.0.0.1:8333
ARTIFACT_STORAGE_S3_REGION=us-east-1
ARTIFACT_STORAGE_S3_BUCKET=matrix-artifacts
ARTIFACT_STORAGE_S3_ACCESS_KEY_ID=seaweedfs
ARTIFACT_STORAGE_S3_SECRET_ACCESS_KEY=seaweedfs-secret
ARTIFACT_STORAGE_S3_USE_PATH_STYLE=true
ARTIFACT_STORAGE_S3_CREATE_BUCKET=true

# Metadata store: postgres (production) | sqlite (dev default)
ARTIFACT_STORAGE_METADATA_PROVIDER=sqlite
ARTIFACT_STORAGE_METADATA_DB_PATH=data/storage/artifacts.db

# Postgres DSN (only used if METADATA_PROVIDER=postgres OR POSTGRES_ENABLED=true)
# POSTGRES_DSN=postgres://user:pass@localhost:5433/matrix_artifacts?sslmode=disable
# POSTGRES_ENABLED=false

# Signed URL TTL (default 15 minutes)
ARTIFACT_STORAGE_SIGNED_URL_TTL_MS=900000

# Signing secret for HMAC tokens. Falls back to AUTH_SECRET / NEXTAUTH_SECRET
# in dev. In production this MUST be set to a 32-byte random hex string.
# Generate: openssl rand -hex 32
ARTIFACT_STORAGE_SIGNING_SECRET=local-dev-artifact-signing-secret

# Public base URL for signed upload/download URLs.
# Defaults to http://<APPSERVICE_HOST>:<APPSERVICE_PORT> if not set.
# ARTIFACT_STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:8090
