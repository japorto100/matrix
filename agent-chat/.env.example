# Agent Chat UI — Environment Variables
# Kopieren nach .env.local und ausfüllen.
# Next.js: NEXT_PUBLIC_ Prefix = im Browser verfügbar

# ─── Go Gateway (BFF Proxy Target — server-side only) ───────────────────────
# Agent Chat BFF Routes (/api/agent/chat etc.) proxyen an den Go Gateway
GO_GATEWAY_BASE_URL=http://127.0.0.1:8090

# ─── LiveKit (Voice AI + Matrix Calls) ──────────────────────────────────────
# lk-jwt-service URL — für Voice Chat Token Austausch
NEXT_PUBLIC_LK_JWT_SERVICE_URL=http://localhost:8080

# ─── AI SDK DevTools (nur Development) ───────────────────────────────────────
# DevTools Viewer: npx @ai-sdk/devtools → http://localhost:4983
# Oder: dev-stack2.ps1 -DevTools
